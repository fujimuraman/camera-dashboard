# fuji-dashboard 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値に書き換えてください
# .env はGit管理外（.gitignore済み）

# === Flask ===
# 起動ポート（デフォルト 8080）
# FUJI_DASH_PORT=8080
# Flask SECRET_KEY（セッション用、ランダムな長い文字列）
# FUJI_DASH_SECRET=your-random-secret-string-here
# 管理者ユーザー名（デフォルト admin）
# FUJI_DASH_USER=admin

# === パスワードハッシュのソルト（重要） ===
# 配布先ごとに固有の値を設定してください。文字列なら何でもOK。
# 一度設定したら変更しないこと（変更するとログイン不可になります）
PASSWORD_SALT=set-your-own-unique-salt-here

# === 仕入れ台帳（Google Sheets） ===
# Google スプレッドシートのID（URLから抽出: docs.google.com/spreadsheets/d/<ここ>/edit）
# 仕入れ台帳を使わない場合は空でOK（その場合、仕入値は inventory 画面で手入力）
SPREADSHEET_ID=
# サービスアカウントJSONファイルのパス（絶対パス推奨）
GOOGLE_CREDS_PATH=C:/path/to/credentials.json

# === SP-API ===
# Shop識別子: amazon-seller-automation の .env のキー名と連動
# 例: SHOP_KEY=fuji なら FUJI_REFRESH_TOKEN, FUJI_LWA_APP_ID 等を参照
SHOP_KEY=fuji
# SP-API .env ファイルのパス（amazon-seller-automation の .env を流用する場合）
SP_API_ENV_PATH=C:/path/to/amazon-seller-automation/.env
# Marketplace ID（A1VC38T7YXB528 = Amazon.co.jp、海外は別値）
# MARKETPLACE_ID=A1VC38T7YXB528
